# Coverage.py configuration
# https://coverage.readthedocs.io/

[run]
source = src
omit =
    tests/*
    alembic/*
    */__init__.py
    */venv/*
    */.venv/*

branch = True
parallel = True

[report]
precision = 2
show_missing = True
skip_covered = False
sort = Cover

# Fail if coverage is below threshold
fail_under = 0

exclude_lines =
    # Default exclude patterns
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod

    # Additional exclude patterns
    pass
    \.\.\.
    raise NotImplemented

[html]
directory = htmlcov

[xml]
output = coverage.xml
